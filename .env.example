# Switch the feed data source. Copy this file to .env.local and tweak as needed,
# then restart the dev server.

# ── Mode 1: Remote (default — leave unset) ──────────────────────────────────
# Pulls directly from upstream GitHub Raw, auto-updated daily at 6am UTC.
# VITE_FEED_BASE=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main

# ── Mode 2: Local cache ─────────────────────────────────────────────────────
# First run `npm run pull-feeds` (or `npm run copy-feeds`) to populate
# public/feeds/, then enable the line below (or use `npm run dev:local`).
# VITE_FEED_BASE=/feeds

# ── Mode 3: Custom ──────────────────────────────────────────────────────────
# E.g. you've forked follow-builders and publish your own feed-*.json:
# VITE_FEED_BASE=https://raw.githubusercontent.com/<your-name>/follow-builders/main
